# Kopiere diese Datei zu ".env" und trage deine Werte ein.
# WICHTIG: ".env" niemals ins öffentliche Repo committen (siehe .gitignore).

# Pflicht:
GEMINI_API_KEY=AIza...                # dein Google-Gemini-Key (gratis: https://aistudio.google.com/apikey)
ADMIN_PASSWORD=bitte-aendern          # Passwort fürs Admin-Panel

# Optional:
PUBLIC_BASE_URL=                      # z. B. https://latein-gfs.onrender.com (für QR/Link)
GEMINI_MODEL=gemini-2.5-flash         # Gratis-Modell für Bewertung + Assistent (Alternative: gemini-2.0-flash)
DB_PATH=game.db                       # Pfad zur SQLite-Datei

# Punktewerte (optional – sonst gelten die Defaults aus app/config.py):
# BASE_POINTS_PER_SENTENCE=100
# PASS_THRESHOLD=60
# TIME_BONUS_MAX=60
# TIME_TARGET_SECONDS=180
# HELP1_PENALTY=15
# HELP2_PENALTY=10
# HELP2_MAX_QUESTIONS=1   # max. beantwortete Assistenten-Fragen pro Satz (0 = unbegrenzt)
# RETRY_PENALTY=0
